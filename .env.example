# Telegram API Credentials
API_ID=123456
API_HASH=abcdef1234567890
BOT_TOKEN=123456789:ABCDEF-GHIJKLMN-OPQRSTUVWXYZ

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/tg_media_bot
REDIS_URL=redis://localhost:6379/0

# Bot Settings
OWNER_ID=123456789
ADMINS=123456789,987654321
CHANNEL_ID=-1001234567890  # For log storage (optional)
FORCE_SUB_CHANNELS=-1001234567890,-1000987654321

# Server Configuration
BASE_URL=https://yourdomain.com
PORT=8000
DEBUG=True

# Link Expiry (in hours, 0 for never)
DEFAULT_EXPIRY=24

# Telethon Multi-Session (Optional)
# List of session strings or paths to .session files
SESSIONS=session1,session2
